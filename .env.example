# Kopiera den här filen till .env och fyll i dina värden

# GitHub Container Registry (krävs)
# Format: ghcr.io/<ditt-github-användarnamn>/<repo-namn>
# Exempel: ghcr.io/johndoe/receiptscanner
GHCR_IMAGE=ghcr.io/<användare>/<repo>

# Anthropic API-nyckel (krävs)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Postgres-credentials (krävs)
POSTGRES_DB=receipts_db
POSTGRES_USER=receipt_user
POSTGRES_PASSWORD=byt-ut-detta-till-ett-starkt-lösenord

# Authelia ForwardAuth (valfritt, default: false)
# Sätt till "true" om appen körs bakom en reverse proxy med Authelia.
# Appen läser då automatiskt Remote-User och Remote-Name från request-headers
# och fyller i användarnamnet på kvitton.
#
# Traefik-exempel (labels på frontend/backend):
#   - "traefik.http.middlewares.authelia.forwardauth.address=http://authelia:9091/api/verify?rd=https://auth.example.com"
#   - "traefik.http.middlewares.authelia.forwardauth.trustForwardHeader=true"
#   - "traefik.http.middlewares.authelia.forwardauth.authResponseHeaders=Remote-User,Remote-Name,Remote-Email,Remote-Groups"
ENABLE_AUTH=false

# Bildkomprimering (valfritt)
IMAGE_MAX_PX=1600   # Max pixlar på längsta sida innan nedskalning
IMAGE_QUALITY=72    # JPEG-kvalitet 1–95 (lägre = mindre fil, sämre kvalitet)
